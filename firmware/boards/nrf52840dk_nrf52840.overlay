/*
 * ══════════════════════════════════════
 * PART:   Pod Firmware — Device Tree Overlay
 * ACTOR:  Claude Opus 4.6
 * PHASE:  18 — nRF52840-DK Pin Mapping
 * ══════════════════════════════════════
 *
 * Pin assignments for ARA Patch sensors:
 *   I2C0: SDA=P0.26, SCL=P0.27 → MAX86176 PPG
 *   SPI1: MOSI=P0.13, MISO=P0.14, SCK=P0.15, CS=P0.11 → LSM6DSO IMU
 *   ADC:  AIN0=P0.02 → NTC Thermistor
 *   PDM:  CLK=P0.25, DATA=P0.24 → MEMS Microphone
 */

&i2c0 {
    status = "okay";
    compatible = "nordic,nrf-twim";
    sda-pin = <26>;
    scl-pin = <27>;
    clock-frequency = <I2C_BITRATE_FAST>;  /* 400kHz */
};

&spi1 {
    status = "okay";
    compatible = "nordic,nrf-spim";
    sck-pin = <15>;
    mosi-pin = <13>;
    miso-pin = <14>;
    cs-gpios = <&gpio0 11 GPIO_ACTIVE_LOW>;
};

&adc {
    status = "okay";
    #address-cells = <1>;
    #size-cells = <0>;

    channel@0 {
        reg = <0>;
        zephyr,gain = "ADC_GAIN_1_6";
        zephyr,reference = "ADC_REF_INTERNAL";
        zephyr,acquisition-time = <ADC_ACQ_TIME_DEFAULT>;
        zephyr,input-positive = <NRF_SAADC_AIN0>;  /* P0.02 */
        zephyr,resolution = <12>;
    };
};
